# ══════════════════════════════════════════════════════════
#  Variables de Entorno — Canasta Básica PROFECO + AI
#  Copia este archivo como .env para desarrollo local.
#  En Cloud Run, configura estas variables directamente
#  en la consola o vía gcloud CLI (ver deploy.sh).
# ══════════════════════════════════════════════════════════

# ── Base de Datos ──────────────────────────────────────────
# Desarrollo local (Docker):
# MONGO_URI=mongodb://localhost:27017/profeco
#
# Producción (MongoDB Atlas):
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/profeco?retryWrites=true&w=majority

# Nombre de la base de datos
MONGO_DB_NAME=profeco

# ── Inteligencia Artificial ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Servidor ───────────────────────────────────────────────
# Cloud Run inyecta PORT automáticamente. Solo necesario en local.
PORT=8080

# ── CORS ───────────────────────────────────────────────────
# En producción, reemplaza * por tu dominio real:
# ALLOWED_ORIGINS=https://tu-app.web.app,https://tu-dominio.com
ALLOWED_ORIGINS=*

# ── Entorno ────────────────────────────────────────────────
ENVIRONMENT=production
