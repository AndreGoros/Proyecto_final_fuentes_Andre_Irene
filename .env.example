# ── Copia este archivo a .env y rellena antes de arrancar ────────────────
# Nunca subas el archivo .env real a git (ya está excluido en .gitignore).

# ── 1. Gemini AI (Obligatorio para el frontend/backend) ──────────────────
# Obtenlo en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# ── 2. Credenciales MongoDB (Docker y Backend) ───────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin1234

MONGO_APP_USER=pipeline_user
MONGO_APP_PASSWORD=pipeline1234

MONGO_DB=precios_db
MONGO_COLLECTION=precios

# URI usada por el pipeline de limpieza y el backend
MONGO_URI=mongodb://pipeline_user:pipeline1234@localhost:27017/precios_db?authSource=admin

# ── 3. Parámetros de Búsqueda y Matemáticas ────────────────────────────────
RADIO_KM=10
MAX_RESULTADOS=50
PRECIO_GASOLINA_LT=25.0
RENDIMIENTO_KM_LT=12.0
